# Part 3 

# Select three strongest features (based on coefficients)
selected_features = ["AveBedrms", "Latitude", "Longitude"]

X_simple = X[selected_features]

# Split data (80/20)
X_train_simple, X_test_simple, y_train, y_test = train_test_split(
    X_simple, y, test_size=0.2, random_state=42
)

# Train simplified linear regression model
lin_reg_simple = LinearRegression()
lin_reg_simple.fit(X_train_simple, y_train)

# Predictions
y_pred_simple = lin_reg_simple.predict(X_test_simple)

# Evaluate performance
mse_simple = mean_squared_error(y_test, y_pred_simple)
rmse_simple = root_mean_squared_error(y_test, y_pred_simple)
r2_simple = r2_score(y_test, y_pred_simple)

print("Simplified Model Performance:")
print(f"Mean Squared Error: {mse_simple:.2f}")
print(f"Root Mean Squared Error: {rmse_simple:.2f}")
print(f"R² Score: {r2_simple:.2f}")

